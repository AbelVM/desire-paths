{
  "name": "desire-paths",
  "version": "1.0.0",
  "description": "Interactive agent-based pedestrian flow simulator that models desire path formation across terrain using H3 hex grids and real-world map data.",
  "keywords": [
    "desire-paths",
    "pedestrian-flow",
    "agent-based-modeling",
    "urban-planning",
    "friction-field",
    "H3-hex-grid",
    "pathfinding",
    "GIS",
    "cartography",
    "walkability"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/abelvm/desire-paths"
  },
  "homepage": "https://abelvm.github.io/desire-paths/",
  "license": "MIT",
  "author": "Abel Vázquez Montoro",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ./src",
    "deploy": "push-dir --dir=dist --branch=gh-pages"
  },
  "dependencies": {
    "@deck.gl/core": "^9.3.6",
    "@deck.gl/geo-layers": "^9.3.6",
    "@deck.gl/layers": "^9.3.6",
    "@deck.gl/mapbox": "^9.3.6",
    "@maplibre/maplibre-gl-geocoder": "^1.9.4",
    "h3-js": "^4.5.0",
    "maplibre-gl": "^5.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/web-worker": "^4.1.9",
    "cssnano": "^8.0.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "push-dir": "^0.4.1",
    "terser": "^5.48.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
